# ── Frontend ──────────────────────────────────────────────────────────────────
# Override the API base URL (leave blank to use the nginx /api proxy in production)
VITE_API_URL=http://localhost:4000/api

# ── Backend ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://study:studypass@localhost:5432/scrollstudy
CORS_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=study
POSTGRES_PASSWORD=studypass
POSTGRES_DB=scrollstudy

# ── AWS (production) ──────────────────────────────────────────────────────────
# AWS_REGION=ap-southeast-1
# AWS_RDS_ENDPOINT=scrollstudy.xxxxx.rds.amazonaws.com
# AWS_ECR_REGISTRY=123456789.dkr.ecr.ap-southeast-1.amazonaws.com
